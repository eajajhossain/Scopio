# ── Copy to .env and fill in. docker-compose reads this file. ──────────────
# .env is gitignored — never commit real secrets.

# Environment: "dev" (auth optional, demo tenant fallback) or "production" (auth required)
ENVIRONMENT=dev

# REQUIRED in production — a long random string used to sign auth tokens.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-change-me-in-production

# Datastores (docker-compose sets these for the containers automatically)
DATABASE_URL=postgresql+asyncpg://app_rls:app_rls@localhost:5432/scopio
REDIS_URL=redis://localhost:6379/0

# Comma-separated allowed browser origins for CORS (leave empty for same-origin only)
CORS_ORIGINS=

# ── AI (optional; the app degrades gracefully without these) ───────────────
# Free LLM for enrichment + the outreach agent (https://console.groq.com/keys)
GROQ_API_KEY=
# Paid alternative — takes priority over Groq if set
ANTHROPIC_API_KEY=

# Enrichment/research LLM endpoint (OpenAI-compatible). Defaults to Groq cloud.
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT=
# The chat/outreach agent uses its OWN endpoint (defaults to Groq cloud).
OUTREACH_BASE_URL=
OUTREACH_MODEL=
# Enrichment batching: businesses processed per Deep-research click, and the cooldown
# before an already-researched business is retried (0 = always retry). Never-tried go first.
ENRICHMENT_MAX_BUSINESSES=25
ENRICHMENT_RECHECK_DAYS=14

# ── Deep research agent (LangGraph + Tavily) ───────────────────────────────
# Web-search key for the deep research agent (https://tavily.com). Key arrives later;
# without it the app falls back to the website-read enrichment path.
TAVILY_API_KEY=

# ── Admin dashboard ─────────────────────────────────────────────────────────
# Comma-separated emails allowed into the cross-tenant Admin dashboard (owner view).
ADMIN_EMAILS=
# Bootstrap admin login (kept only here in .env — gitignored, private). If both are
# set, the app ensures this account exists on startup and keeps its password in sync,
# so this IS your admin login. Use a strong password. Leave blank to skip.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Discovery (optional) ───────────────────────────────────────────────────
# Free 2nd source, merged with OpenStreetMap (https://myprojects.geoapify.com)
GEOAPIFY_API_KEY=
# Free web-search to find missing business websites (https://brave.com/search/api)
BRAVE_API_KEY=

# ── Email sending ──────────────────────────────────────────────────────────
# Per-user SMTP is set in-app (Connect email). This is just the default From shown.
ORGANIZER_EMAIL=you@example.com

# ── Follow-up reminders (optional; sensible defaults) ──────────────────────
# When the owner agrees to a call but gives no date, remind this many days out…
REMINDER_DEFAULT_DAYS=2
# …at this local hour (in the tenant's timezone).
REMINDER_DEFAULT_HOUR=10
# Base for the auto-minted video room both sides join (point at self-hosted Jitsi if you have one).
JITSI_BASE_URL=https://meet.jit.si

# ── Phone / click-to-call (optional) ───────────────────────────────────────
# Region used to read bare local numbers with no country code (e.g. US, GB, AE).
# Numbers that already include a country code dial correctly worldwide regardless.
PHONE_DEFAULT_REGION=IN
